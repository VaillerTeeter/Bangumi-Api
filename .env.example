# GitHub CLI Token 配置模板
# 将此文件复制为 .env，并填入你的 GitHub Personal Access Token
# 复制命令：cp .env.example .env（Linux/macOS）或 Copy-Item .env.example .env（Windows）

GH_TOKEN=your_github_personal_access_token_here

# Bangumi API Token（用于集成测试中的认证接口，如收藏/取消收藏等）
# 在 https://next.bgm.tv/demo/access-token 创建 Personal Access Token
BGM_TOKEN=your_bangumi_personal_access_token_here
